# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

before_all do
  ENV["VERSION_NAME"] = `git log -1 --format=%cd --date=format:"%Y.%m.%d"`.strip
end
    desc "Generate fresh backup data for screenshots"
    lane :generate_backup_data do
      project_root = File.expand_path("..", __dir__)
      output_path = File.join(project_root, "build/generated/test-data/screenshot_test_backup.json")
      sh "python3", File.join(project_root, "scripts/generate_screenshot_backup.py"), output_path
    end


# Android
platform :android do

    desc "Build the release artifact"
    lane :build_release do
        gradle(task: "clean bundleRelease", flags: "-PbuildNumber=#{options[:build_number]} -PversionName=#{ENV['VERSION_NAME']}")
    end

    desc "Install and run Emulator"
    lane :run_android_emulator do
        android_emulator(
            name: "maestro_test_emulator",
            package: "system-images;android-36;google_apis;x86_64",
            device: "pixel_6"
        )
    end

    lane :test do |options|
        gradle(task: "test")
    end

    desc "Run the project Linter"
    lane :lint do
       gradle(task: "detekt --continue")
    end

    desc "Push test backup file to Android device/emulator"
    lane :push_backup_to_device do
      project_root = File.expand_path("..", __dir__)
      sh File.join(project_root, "scripts/push-test-backup.sh"), "android"
    end

    desc "Generate Play Store screenshots locally"
    lane :generate_play_store_screenshots do
      project_root = File.expand_path("..", __dir__)

      # 1. Generate fresh backup data
      generate_backup_data

      # 2. Push backup file to device
      push_backup_to_device

      # 3. Build and install debug APK
      gradle(task: ":app-android:installDebug")

      # 3a. Wait for package manager and verify app launches
      sh "adb", "shell", "pm", "wait-for-device"
      sleep 5

      # 3b. Launch app to verify it's alive
      sh "adb", "shell", "am", "start", "-n", "com.lift.bro/.android.MainActivity"
      sleep 10

      # 3c. Capture diagnostic logcat (app crashes and errors)
      sh "adb", "logcat", "-d", "-t", "200", "-s", "AndroidRuntime:E", "System.err:W"

      # 3d. Verify the backup file was pushed
      sh "adb", "shell", "ls", "-la", "/sdcard/Download/screenshot_test_backup.json"

      # 4. Run Maestro screenshot flows
      Dir.chdir(project_root) do
        sh "maestro", "test", File.join(project_root, ".maestro/screenshots/")
      end


      Dir.glob(File.join(project_root, "build/generated/store-screenshots/*.png")).each do |png|
        sh "convert", png, "-resize", "1080x2340!", png
      end

      # 6. Run frameit to add device frames
      Dir.chdir(File.join(project_root, "build/generated/store-screenshots")) do
        sh "fastlane", "frameit"
      end

      # 5. Copy screenshots to frameit directory and resize to Pixel 5 dimensions
      sh "mkdir", "-p", File.join(project_root, "fastlane/metadata/android/en-US/images/phoneScreenshots")
      Dir.glob(File.join(project_root, "build/generated/store-screenshots/*_framed.png")).each do |png|
        sh "cp", png, File.join(project_root, "fastlane/metadata/android/en-US/images/phoneScreenshots/")
      end

      UI.success "Framed screenshots ready in fastlane/metadata/android/en-US/images/phoneScreenshots/"
    end

    desc "Build release AAB"
    lane :build_release_aab do |options|
      build_number = options[:build_number]
      UI.user_error!("build_number is required") unless build_number
      gradle(task: "bundleRelease", flags: "-PbuildNumber=#{build_number}")
    end

    desc "Generate changelog from release_notes.json"
    lane :generate_changelog do |options|
      build_number = options[:build_number]
      UI.user_error!("build_number is required") unless build_number

      project_root = File.expand_path("..", __dir__)
      version_code = build_number.to_i + 156
      changelog_dir = File.join(project_root, "fastlane/metadata/android/en-US/changelogs")
      sh "mkdir", "-p", changelog_dir

      release_notes_path = File.join(project_root,
        "presentation/compose/src/commonMain/composeResources/files/release_notes.json")
      release_notes = JSON.parse(File.read(release_notes_path))

      android_notes = release_notes.select { |entry|
        entry["notes"].any? { |n| n["platform"] == "all" || n["platform"] == "android" }
      }.last(3).reverse

      lines = []
      android_notes.each do |ver|
        lines << "<b>Version #{ver["versionId"]}</b>"
        ver["notes"].each do |note|
          next unless note["platform"] == "all" || note["platform"] == "android"
          lines << "<li>#{note["en"]}</li>"
        end
        lines << ""
      end

      File.write(File.join(changelog_dir, "#{version_code}.txt"), lines.join("\n").strip)
      UI.success "Changelog written for versionCode #{version_code}"
    end

    desc "Upload AAB + metadata to Google Play Store"
    lane :upload_to_playstore do |options|
      build_number = options[:build_number]
      project_root = File.expand_path("..", __dir__)

      UI.user_error!("build_number is required") unless build_number

      supply(
        track: "beta",
        version_code: build_number,
        release_status: "completed",
        json_key: File.join(project_root, "key.json"),
        metadata_path: File.join(project_root, "fastlane/metadata/android"),
      )
    end

    desc "Deploy a new version to Google Play beta (sequential, for local use)"
    lane :deploy do |options|
      gradle(task: "clean bundleRelease", flags: "-PbuildNumber=#{options[:build_number]} -PversionName=#{ENV['VERSION_NAME']}")
      supply(track: "beta")
      build_number = options[:build_number]
      UI.user_error!("build_number is required") unless build_number

      generate_play_store_screenshots
      build_release_aab(build_number: build_number)
      generate_changelog(build_number: build_number)
      upload_to_playstore(build_number: build_number)
    end

    desc "Promote internal build to prod on Google Play"
    lane :promote_internal_to_prod do

        # fetch builds from bets
        testing_track_info = google_play_track_version_codes(
          track: 'beta',
          package_name: "com.lift.bro"
        )

        # if build exists promote it
        if testing_track_info && testing_track_info.first
          version_codes_to_promote = testing_track_info.first
          UI.message "Promoting version codes #{version_codes_to_promote} from 'internal testing' to 'production'"

          supply(
            track: 'beta',
            track_promote_to: "production",
            version_code: version_codes_to_promote,
            track_promote_release_status: 'completed',
            package_name: "com.lift.bro",
          )
          UI.success "Successfully promoted build with version codes #{version_codes_to_promote} to production!"
        else
          UI.important "No active releases found in 'internal testing' track to promote."
          exit(1)
        end
      end
end

# iOS
platform :ios do
  before_all do
    if ENV["CI"] == "true"
      setup_ci
    end

    unless ENV["APPSTORE_KEY_ID"].nil? || ENV["APPSTORE_KEY_ID"].empty? || ENV["APPSTORE_PRIVATE_KEY"].nil?
      app_store_connect_api_key(
        key_id: ENV["APPSTORE_KEY_ID"],
        issuer_id: ENV["APPSTORE_ISSUER_ID"],
        key_content: ENV["APPSTORE_PRIVATE_KEY"]
      )
    end

  end

  desc "Sync iOS Development Code Signing Identities using match"
  lane :match_development do
    match(
      type: "development",
      readonly: true,
      git_url: ENV["MATCH_GIT_URL"],
      git_branch: "main",
      keychain_name: "build.keychain",
      keychain_password: ENV["MATCH_PASSWORD"],
      username: ENV["FASTLANE_USER"]
    )
  end

  desc "Sync iOS App Store Code Signing Identities using match"
  lane :match_appstore do |options|
    match_params = {
      type: "appstore",
      readonly: options[:readonly].nil? ? true : options[:readonly],
      force: options[:force] || false,
      git_url: ENV["MATCH_GIT_URL"],
      git_branch: "main"
    }

    if ENV["CI"] != "true"
      match_params[:keychain_name] = "build.keychain"
      match_params[:keychain_password] = ENV["MATCH_PASSWORD"]
    end

    unless ENV["FASTLANE_USER"].nil? || ENV["FASTLANE_USER"].empty?
      match_params[:username] = ENV["FASTLANE_USER"]
    end

    match(match_params)
  end

  desc "Build the release artifact for iOS"
  lane :build_release do |options|
    match_appstore

    setup_keychain_for_codesign

    gym(
      scheme: "iosApp",
      project: "iosApp/iosApp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/artifacts/ios",
      output_name: "ios_app_release.ipa",
      clean: true,
      silent: false,
      xcargs: options[:build_number] ? "MARKETING_VERSION=#{`git log -1 --format=%cd --date=format:%Y.%m.%d`.strip} CURRENT_PROJECT_VERSION=#{options[:build_number].to_i + 156}" : nil,
    )
  end

  desc "Build the debug artifact for iOS"
  lane :build_debug do |options|
    match_development

    xcargs = options[:build_number] ? "MARKETING_VERSION=#{`git log -1 --format=%cd --date=format:%Y.%m.%d`.strip} CURRENT_PROJECT_VERSION=#{options[:build_number].to_i + 156}" : nil

    gym(
      scheme: "iosApp",
      project: "iosApp/iosApp.xcodeproj",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      derived_data_path: options[:derived_data_path],
      clean: true,
      silent: false,
      skip_package_ipa: true,
      skip_archive: true,
      xcargs: xcargs,
    )
  end

  desc "Build debug artifact for physical iOS device"
  lane :build_debug_device do |options|
    match_development
    device_udid = options[:device_udid] || ENV["DEVICE_UDID"]
    UI.user_error!("device_udid is required. Pass via options or DEVICE_UDID env variable.") unless device_udid

    project_root = File.expand_path("..", __dir__)
    derived_data = File.join(project_root, "fastlane/build/DerivedData/ios")

    setup_keychain_for_codesign

    xcargs = "PROVISIONING_PROFILE_SPECIFIER='match Development com.lift.bro' CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=VZPX29WT9H"
    if options[:build_number]
      xcargs += " MARKETING_VERSION=#{`git log -1 --format=%cd --date=format:%Y.%m.%d`.strip} CURRENT_PROJECT_VERSION=#{options[:build_number].to_i + 156}"
    end

    gym(
      scheme: "iosApp",
      project: File.join(project_root, "iosApp/iosApp.xcodeproj"),
      configuration: "Debug",
      destination: "platform=iOS,id=#{device_udid}",
      derived_data_path: derived_data,
      export_method: "development",
      skip_archive: true,
      silent: true,
      xcargs: xcargs
    )

    app_path = "#{derived_data}/Build/Products/Debug-iphoneos/Lift Bro.app"

    sh "xcrun", "devicectl", "device", "install", "app", "--device", device_udid, app_path
    sh "xcrun", "devicectl", "device", "process", "launch", "--device", device_udid, "--console", "com.lift.bro"
  end

  desc "Build release artifact for physical iOS device (development signing)"
  lane :build_release_device do |options|
    match_development
    device_udid = options[:device_udid] || ENV["DEVICE_UDID"]
    UI.user_error!("device_udid is required. Pass via options or DEVICE_UDID env variable.") unless device_udid

    project_root = File.expand_path("..", __dir__)
    derived_data = File.join(project_root, "fastlane/build/DerivedData/ios")

    setup_keychain_for_codesign

    xcargs = "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=VZPX29WT9H"
    if options[:build_number]
      xcargs += " MARKETING_VERSION=#{`git log -1 --format=%cd --date=format:%Y.%m.%d`.strip} CURRENT_PROJECT_VERSION=#{options[:build_number].to_i + 156}"
    end

    gym(
      scheme: "iosApp",
      project: File.join(project_root, "iosApp/iosApp.xcodeproj"),
      configuration: "Release",
      destination: "platform=iOS,id=#{device_udid}",
      derived_data_path: derived_data,
      export_method: "development",
      skip_archive: true,
      silent: true,
      xcargs: xcargs
    )

    app_path = "#{derived_data}/Build/Products/Release-iphoneos/Lift Bro.app"

    sh "xcrun", "devicectl", "device", "install", "app", "--device", device_udid, app_path
    sh "xcrun", "devicectl", "device", "process", "launch", "--device", device_udid, "--console", "com.lift.bro"
  end

  lane :test do |options|gradle(task: "test")
  end

  desc "Run Linter for iOS (e.g., SwiftLint)"
  lane :lint do
    UI.message("No specific iOS linting configured in Fastfile.")
  end

  desc "Deploy a new beta version to TestFlight for iOS"
  lane :beta do |options|
    build_release(build_number: options[:build_number]) # Reuse the build_release lane

    # Upload to TestFlight
    testflight(
      ipa: "build/artifacts/ios/ios_app_release.ipa",
      changelog: "Updated app to a new beta version from CI. Build: #{options[:build_number]}",
      notify_external_testers: true, # Set to true to automatically notify testers
      # groups: ["Internal Testers"] # Optional: specific groups to notify
    )
  end

  desc "Push test backup file to iOS simulator"
  lane :push_backup_to_simulator do
    project_root = File.expand_path("..", __dir__)
    sh File.join(project_root, "scripts/push-test-backup.sh"), "ios"
  end

  desc "Generate App Store screenshots locally"
  lane :generate_app_store_screenshots do
    project_root = File.expand_path("..", __dir__)
    device_type = "iPhone 17 Pro"

    # 1. Boot simulator
    booted = `xcrun simctl list devices booted`.include?(device_type)
    unless booted
      sh "xcrun", "simctl", "boot", device_type
    end
    simulator_udid = `xcrun simctl list devices available`.match(/#{device_type} \(([A-F0-9-]+)\)/)[1]
    UI.message "Simulator booted: #{device_type} (#{simulator_udid})"

    begin
      # 2. Generate fresh backup data
      generate_backup_data

      # 3. Build debug IPA for simulator
      derived_data = File.join(project_root, "build/generated/derived-data/ios")
      build_debug(derived_data_path: derived_data)

      # 4. Install app on simulator
      app_path = File.join(derived_data, "Build/Products/Debug-iphonesimulator/Lift Bro.app")
      UI.user_error!("Built app not found at #{app_path}") unless File.exist?(app_path)
      sh "xcrun", "simctl", "install", simulator_udid, app_path

      # 5. Push backup file to simulator
      push_backup_to_simulator

      # 6. Run Maestro screenshot flows
      Dir.chdir(project_root) do
        sh "maestro", "test", File.join(project_root, ".maestro/screenshots/")
      end

      # 7. Copy screenshots to frameit directory
      sh "mkdir", "-p", File.join(project_root, "fastlane/screenshots/en-US/images/phoneScreenshots")
      Dir.glob(File.join(project_root, "build/generated/store-screenshots/*.png")).each do |png|
        sh "cp", png, File.join(project_root, "fastlane/screenshots/en-US/images/phoneScreenshots/")
      end

      # 8. Run frameit to add device frames
      Dir.chdir(File.join(project_root, "fastlane/screenshots")) do
        sh "fastlane", "frameit", "ios"
      end

      UI.success "Framed screenshots ready in fastlane/screenshots/en-US/images/phoneScreenshots/"
    ensure
      # Shut down simulator
      sh "xcrun", "simctl", "shutdown", simulator_udid rescue nil
      UI.message "Simulator shut down."
    end
  end

  desc "Submit a new version to the App Store for iOS"
  lane :deploy do |options|
    # This lane would be similar to `beta` but with `deliver` for App Store submission
    # and possibly different versioning logic.
    UI.message("Building and submitting to App Store for iOS...")
    build_release(build_number: options[:build_number])

#     deliver(
#       ipa: "build/artifacts/ios/ios_app_release.ipa",
#       # Add your App Store Connect metadata here (e.g., `app_review_information`, `pricing_tier`, etc.)
#       # It's recommended to pull metadata from `fastlane/metadata` using `deliver init`
#       # or specify directly here.
#       # For first submission, you'll need all metadata. For updates, only new/changed items.
# #       force: true, # Use with caution, overwrites existing metadata
#       skip_metadata: true, # Set to true if you don't update metadata via Fastlane
#       skip_screenshots: true, # Set to true if you don't upload screenshots via Fastlane
#       submit_for_review: true, # Automatically submit for review after upload
#       automatic_release: true, # Release immediately after review (or set a date)
#       # release_build_status: "READY_FOR_SALE" # Or other values if managing through App Store Connect
#     )
  end

  desc "Get the latest TestFlight build version"
  lane :latest_testflight_version do
    require 'spaceship'

    builds = Spaceship::ConnectAPI::Build.all(
      filter: { processingState: "VALID" },
      sort: "-uploadedDate",
      limit: 1
    )

    version = builds.first&.app_version
    UI.user_error!("No valid TestFlight builds found - run ios-beta-build first") unless version

    puts "VERSION:#{version}"
  end

  desc "Submit existing TestFlight build for App Store review"
  lane :promote do |options|
    deliver(
      submit_for_review: true,
      automatic_release: true,
      skip_build_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      app_version: options[:app_version]
    )
  end

  def setup_keychain_for_codesign
    if ENV["CI"] == "true"
      # Already handled in before_all after setup_ci
      return
    end

    keychain_path = File.expand_path("~/Library/Keychains/build.keychain-db")
    if File.exist?(keychain_path)
      password = ENV["MATCH_PASSWORD"] || ""
      sh "security", "unlock-keychain", "-p", password, keychain_path, log: false
      sh "security", "set-key-partition-list", "-S", "apple-tool:,apple:,codesign:", "-s", "-k", password, keychain_path, log: false
    else
      UI.important("Keychain not found at #{keychain_path}, skipping keychain setup")
    end
  end

end # End of iOS platform block

